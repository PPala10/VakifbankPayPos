@{
    ViewData["Title"] = "Üye İşyeri Başvuru Formu";
}

<div class="max-w-4xl mx-auto space-y-6">
    <div class="text-center space-y-2">
        <h2 class="text-2xl font-extrabold text-[#0F172A]">Gelişmiş Üye İşyeri Başvuru Formu</h2>
        <p class="text-slate-500 text-sm">İşletmenize özel POS kurulumu ve başvuru onayı için bilgilerinizi eksiksiz doldurunuz.</p>
    </div>

    <form id="form-onboarding" onsubmit="saveOnboardingAndNext(event)" class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 space-y-6 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1 md:col-span-2">
                <label class="text-xs font-bold text-slate-500 uppercase">Firma Ticari Unvanı *</label>
                <input type="text" id="m-name" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="VakıfPayPos Yazılım Ltd. Şti.">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Vergi Numarası *</label>
                <input type="text" id="m-tax" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="1234567890">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Vergi Dairesi *</label>
                <input type="text" id="m-taxoffice" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="Kadıköy V.D.">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Yetkili Ad Soyad *</label>
                <input type="text" id="m-manager" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="Ahmet Yılmaz">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Yetkili TCKN *</label>
                <input type="number" id="m-tckn" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="11111111111">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Telefon *</label>
                <input type="tel" id="m-phone" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="0532 000 00 00">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-slate-500 uppercase">E-posta *</label>
                <input type="email" id="m-email" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="info@firma.com">
            </div>
            <div class="space-y-1 md:col-span-2">
                <label class="text-xs font-bold text-slate-500 uppercase">Hakediş IBAN *</label>
                <input type="text" id="m-iban" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:ring-2 focus:ring-[#FFC20E]" placeholder="TR67 0001 5001 5800 0001 9827 34">
            </div>
        </div>

        <div class="flex justify-between items-center pt-4 border-t">
            <a href="/" class="text-slate-500 text-xs font-bold"><i class="fa-solid fa-arrow-left"></i> Kataloğa Dön</a>
            <button type="submit" class="bg-[#0F172A] hover:bg-slate-800 text-[#FFC20E] text-xs font-extrabold px-6 py-3 rounded-xl border border-[#FFC20E]/20">
                Ödeme ve Konum Adımına Geç <i class="fa-solid fa-chevron-right ml-1"></i>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function saveOnboardingAndNext(e) {
            e.preventDefault();
            const customerData = {
                CompanyName: document.getElementById('m-name').value,
                TaxNumber: document.getElementById('m-tax').value,
                TaxOffice: document.getElementById('m-taxoffice').value,
                ManagerName: document.getElementById('m-manager').value,
                ManagerTCKN: parseInt(document.getElementById('m-tckn').value || "0"),
                Phone: document.getElementById('m-phone').value,
                Email: document.getElementById('m-email').value,
                IBAN: document.getElementById('m-iban').value,
                CustomerType: "corp"
            };
            sessionStorage.setItem('vakif_customer', JSON.stringify(customerData));
            window.location.href = '/Home/Checkout';
        }
    </script>
}