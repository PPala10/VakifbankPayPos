@model VakifPayPos.Models.Pos

@{
    ViewData["Title"] = "Yeni POS Cihazı Ekle";
}

<div class="max-w-3xl mx-auto space-y-6">
    <div class="text-center space-y-2">
        <span class="bg-[#0F172A] text-[#FFC20E] text-xs font-extrabold px-3 py-1 rounded-full border border-[#FFC20E]/30 uppercase tracking-widest">Yönetim Paneli</span>
        <h1 class="text-3xl font-extrabold text-[#0F172A]">Yeni POS Cihazı Tanımla</h1>
        <p class="text-slate-500 text-sm">PostgreSQL veritabanına eklenecek yeni fiziki POS cihazı parametrelerini giriniz.</p>
    </div>

    <form asp-action="AddPos" method="post" class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 space-y-6 shadow-sm">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Cihaz Adı -->
            <div class="space-y-1.5 md:col-span-2">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">POS Cihaz Adı *</label>
                <input asp-for="posName" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]" placeholder="Örn: VakıfAndroid Smart POS">
            </div>

            <!-- Cihaz Tipi (Kategori) -->
            <div class="space-y-1.5">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Cihaz Tipi *</label>
                <select asp-for="posType" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]">
                    <option value="sabit">Sabit POS</option>
                    <option value="mobil">Mobil POS</option>
                    <option value="okc">Yazarkasa ÖKC</option>
                    <option value="vuk507">VUK 507 Entegre</option>
                </select>
            </div>

            <!-- Fiyat Tipi -->
            <div class="space-y-1.5">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Fiyatlandırma Türü *</label>
                <select asp-for="priceType" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]">
                    <option value="Aylık Kiralama">Aylık Kiralama</option>
                    <option value="Satın Al / Peşin">Satın Al / Peşin</option>
                </select>
            </div>

            <!-- Fiyat (TL) -->
            <div class="space-y-1.5">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Fiyat (TL) *</label>
                <input asp-for="price" type="number" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]" placeholder="199">
            </div>

            <!-- Komisyon Oranı (%) -->
            <div class="space-y-1.5">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Komisyon Oranı (%) *</label>
                <input asp-for="commisionRate" type="number" step="0.01" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]" placeholder="1.45">
            </div>

            <!-- Valör Süresi -->
            <div class="space-y-1.5">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Valör Süresi *</label>
                <select asp-for="valorType" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]">
                    <option value="Aynı Gün">Aynı Gün</option>
                    <option value="Ertesi Gün">Ertesi Gün</option>
                    <option value="2 İş Günü">2 İş Günü</option>
                </select>
            </div>

            <!-- Satın Alma Mı / Kiralama Mı? -->
            <div class="space-y-1.5 flex items-center pt-6">
                <input asp-for="isPurchase" type="checkbox" class="w-4 h-4 text-[#0F172A] rounded border-slate-300 focus:ring-[#FFC20E]">
                <label asp-for="isPurchase" class="ml-2 text-xs font-bold text-slate-700">Bu cihaz peşin satın alma modeliyle mi satılıyor?</label>
            </div>

            <!-- Açıklama -->
            <div class="space-y-1.5 md:col-span-2">
                <label class="text-xs font-extrabold text-slate-600 uppercase tracking-wider">Cihaz Açıklaması *</label>
                <textarea asp-for="description" rows="3" required class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#FFC20E]" placeholder="Cihazın teknik özelliklerini ve avantajlarını giriniz..."></textarea>
            </div>
        </div>

        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
            <a href="/" class="text-xs font-bold text-slate-500 hover:text-slate-800">
                <i class="fa-solid fa-arrow-left mr-1"></i> Kataloğa Dön
            </a>
            <button type="submit" class="bg-[#0F172A] hover:bg-slate-800 text-[#FFC20E] text-xs font-extrabold px-6 py-3 rounded-xl border border-[#FFC20E]/20 shadow-sm transition-all flex items-center space-x-2">
                <i class="fa-solid fa-plus"></i>
                <span>Veritabanına Ekle</span>
            </button>
        </div>
    </form>
</div>